# Copy to .env and fill in.  Every knob the app reads is listed here; all have
# sensible defaults, so the only thing you *must* set is a model backend below.

# ── Model backend ────────────────────────────────────────────────────────────
# If ANTHROPIC_API_KEY is set, the hosted-Claude backend is used automatically;
# otherwise the local OpenAI-compatible endpoint is used.  LLM_PROVIDER forces
# the choice: "anthropic" or "local" (unset = auto-detect).
# LLM_PROVIDER=anthropic

# Option A — hosted Claude (zero local setup)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5       # default model for the Anthropic backend

# Option B — local OpenAI-compatible endpoint (llama.cpp / Ollama / vLLM)
LLM_ENDPOINT=http://localhost:8000/v1
LOCAL_MODEL=qwen3.6-35b-a3b             # default model for the local backend

# Override the model for whichever backend is active.  Ignored on the Anthropic
# backend unless it starts with "claude" (so a leftover local name can't break it).
# LLM_MODEL=
# LLM_TEMPERATURE=0.3                    # sampling temperature (both backends)
# MAX_OUTPUT_TOKENS=                     # hard cap on response length; unset = to EOS
# OPENAI_API_KEY=sk-not-needed-for-local # dummy is set for you on local endpoints

# ── Console tracing (separate from LangSmith; may print PII to stdout) ────────
# TRACE_ENABLED=0                        # 1 = log tool calls + timing (redacted)
# TRACE_RAW=0                            # 1 = log raw arg values (debug only)

# ── LangSmith tracing (opt-in — set the API key to enable) ───────────────────
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=musicstore-chatbot
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com   # EU: https://eu.api.smith.langchain.com
