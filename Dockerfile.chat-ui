# Dockerfile.chat-ui — builds LangChain's agent-chat-ui.
#
# The upstream repo (github.com/langchain-ai/agent-chat-ui) ships no Dockerfile,
# so we clone it at a pinned ref and build it here.  The browser-facing config
# (NEXT_PUBLIC_*) is inlined into the client bundle at build time; the API key and
# the in-network agent URL are supplied at runtime (see docker-compose.yml).
FROM node:22-bookworm-slim

# git to clone the UI; corepack to pin pnpm from the repo's packageManager field.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable

WORKDIR /app

# Pin the UI for reproducible builds; override with --build-arg CHAT_UI_REF=<sha>.
ARG CHAT_UI_REF=main
RUN git clone --depth 1 --branch "${CHAT_UI_REF}" \
    https://github.com/langchain-ai/agent-chat-ui.git .

RUN pnpm install --frozen-lockfile

# NEXT_PUBLIC_* are read by the browser, so they must be baked at build time.
#   NEXT_PUBLIC_API_URL      -> the UI's own same-origin /api proxy (avoids CORS)
#   NEXT_PUBLIC_ASSISTANT_ID -> the graph id from langgraph.json ("support_bot")
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_ASSISTANT_ID
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_ASSISTANT_ID=${NEXT_PUBLIC_ASSISTANT_ID}
RUN pnpm build

ENV NODE_ENV=production
EXPOSE 3000
CMD ["pnpm", "start"]
