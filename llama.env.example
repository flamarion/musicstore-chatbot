# llama.cpp server config — copy to `llama.env` and edit for your GPU host.
# The ggml-org/llama.cpp:server-cuda image reads these LLAMA_ARG_* env vars.
# Docs: https://github.com/ggml-org/llama.cpp/tree/master/tools/server

# Path to the GGUF inside the container (mounted from ${HOME}/models).
LLAMA_ARG_MODEL=/models/your-model.gguf

# Bind on all interfaces inside the container, on the port the compose publishes.
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8033

# The model id reported at /v1/models — keep it in sync with LLM_MODEL in .env.
LLAMA_ARG_ALIAS=qwen3.6-35b-a3b

# Offload everything to GPU; grow the context to fit the tool-heavy prompts.
LLAMA_ARG_N_GPU_LAYERS=999
LLAMA_ARG_CTX_SIZE=8192
